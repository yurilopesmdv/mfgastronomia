# ===== Banco de dados (Neon) =====
# Pooled connection (com -pooler no host) — usada pelo app em runtime
DATABASE_URL="postgresql://user:password@host-pooler.region.aws.neon.tech/dbname?sslmode=require"
# Direct connection (sem -pooler) — usada pelo prisma migrate
DIRECT_URL="postgresql://user:password@host.region.aws.neon.tech/dbname?sslmode=require"

# ===== Auth.js =====
# Gere com: openssl rand -base64 32
AUTH_SECRET=""
# URL pública do app (em prod: https://mfgastronomia.com.br)
AUTH_URL="http://localhost:3000"

# ===== Cloudinary =====
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
# Único valor exposto ao cliente (usado pelo widget de upload)
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=""

# ===== Seed inicial =====
# Usado apenas pelo prisma/seed.ts
SEED_ADMIN_EMAIL="admin@mfgastronomia.com.br"
SEED_ADMIN_PASSWORD="troque-esta-senha"
SEED_ADMIN_NAME="Admin MF"

# ===== Rate limit (Dia 2 — opcional) =====
