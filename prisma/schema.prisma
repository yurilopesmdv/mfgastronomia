// MF Gastronomia — schema do banco
// Docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Menu {
  id             String             @id @default(cuid())
  slug           String             @unique
  name           String
  description    String             @db.Text
  mainImageUrl   String
  pricePerPerson Decimal            @db.Decimal(10, 2)
  minPeople      Int                @default(10)
  isActive       Boolean            @default(true)
  order          Int                @default(0)
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  items          MenuItem[]
  galleryImages  MenuGalleryImage[]
  addons         MenuAddon[]
  priceTiers     MenuPriceTier[]
  leads          Lead[]
}

// Faixas de preço por quantidade de pessoas. Aplica o preço da faixa
// com maior `minPeople` que seja <= quantidade. Se nenhuma se aplica,
// usa Menu.pricePerPerson como base.
model MenuPriceTier {
  id             String   @id @default(cuid())
  menuId         String
  minPeople      Int
  pricePerPerson Decimal  @db.Decimal(10, 2)
  order          Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  menu           Menu     @relation(fields: [menuId], references: [id], onDelete: Cascade)

  @@unique([menuId, minPeople])
  @@index([menuId])
}

// Adicionais por cardápio (cobrados por pessoa). Cliente marca no público.
model MenuAddon {
  id             String   @id @default(cuid())
  menuId         String
  name           String
  description    String?
  pricePerPerson Decimal  @db.Decimal(10, 2)
  order          Int      @default(0)
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  menu           Menu     @relation(fields: [menuId], references: [id], onDelete: Cascade)

  @@index([menuId])
}

enum MenuItemCategory {
  APERITIVO
  CARNE
  ACOMPANHAMENTO
}

model MenuItem {
  id       String           @id @default(cuid())
  menuId   String
  category MenuItemCategory
  name     String
  order    Int              @default(0)

  menu     Menu             @relation(fields: [menuId], references: [id], onDelete: Cascade)

  @@index([menuId])
}

model MenuGalleryImage {
  id     String @id @default(cuid())
  menuId String
  url    String
  order  Int    @default(0)

  menu   Menu   @relation(fields: [menuId], references: [id], onDelete: Cascade)

  @@index([menuId])
}

model PortfolioImage {
  id        String   @id @default(cuid())
  url       String
  caption   String?
  order     Int      @default(0)
  createdAt DateTime @default(now())
}

// Singleton — sempre exatamente uma linha (id = "default")
model SiteSettings {
  id                    String   @id @default("default")
  whatsappNumber        String
  defaultContactMessage String   @db.Text
  heroTitle             String
  heroSubtitle          String   @db.Text
  aboutText             String   @db.Text
  contactText           String   @db.Text
  waiterAdditionalPrice Decimal  @db.Decimal(10, 2) @default(0)
  logoUrl               String?
  heroImageUrl          String?
  aboutImageUrl         String?
  ogImageUrl            String?

  // SEO / negócio
  siteUrl               String?
  email                 String?
  phoneFallback         String?
  instagramHandle       String?
  facebookUrl           String?
  priceRange            String?
  addressCity           String?
  addressRegion         String?
  addressStreet         String?
  latitude              Decimal? @db.Decimal(10, 7)
  longitude             Decimal? @db.Decimal(10, 7)

  // Logo invertido (para fundos escuros, ex: footer). Opcional.
  logoUrlDark           String?

  // Toggles de seções da home
  showFeatures          Boolean  @default(true)
  showAbout             Boolean  @default(true)
  showFeaturedMenus     Boolean  @default(true)
  showHowItWorks        Boolean  @default(true)
  showPortfolioPreview  Boolean  @default(true)
  showFinalCta          Boolean  @default(true)
  showFaq               Boolean  @default(true)
  showTestimonials      Boolean  @default(true)
  showServiceArea       Boolean  @default(true)

  // Área de atendimento
  serviceAreaText       String?  @db.Text

  updatedAt             DateTime @updatedAt
}

// Diferenciais editáveis exibidos na home (substitui o array hardcoded)
model HomeFeature {
  id        String   @id @default(cuid())
  title     String
  body      String   @db.Text
  order     Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Passos da seção "Como funciona"
model HomeStep {
  id        String   @id @default(cuid())
  title     String
  body      String   @db.Text
  order     Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Perguntas frequentes
model Faq {
  id        String   @id @default(cuid())
  question  String
  answer    String   @db.Text
  order     Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Depoimentos de clientes
model Testimonial {
  id          String   @id @default(cuid())
  authorName  String
  authorEvent String?
  quote       String   @db.Text
  rating      Int?
  photoUrl    String?
  order       Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

enum LeadSource {
  QUICK_CONTACT
  MENU_QUOTE
}

model Lead {
  id              String     @id @default(cuid())
  source          LeadSource
  name            String
  phone           String
  menuId          String?
  peopleCount     Int?
  waitersCount    Int?
  eventDate       String?
  city            String?
  neighborhood    String?
  calculatedTotal Decimal?   @db.Decimal(10, 2)
  // Snapshot dos adicionais escolhidos no momento do orçamento.
  // Formato: [{ id, name, pricePerPerson }]
  selectedAddons  Json?
  createdAt       DateTime   @default(now())

  menu            Menu?      @relation(fields: [menuId], references: [id], onDelete: SetNull)

  @@index([createdAt])
}
